---

<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">

<style>
  .arcade-section { background: #060b38; padding-block: clamp(3rem, 6vw, 5rem); min-height: 80vh; }
  .arcade-wrap { max-width: 460px; margin-inline: auto; font-family: "Press Start 2P", monospace; color: var(--blue-pale); }
  .arcade-wrap, .arcade-wrap * { box-sizing: border-box; }

  /* CRT vibes */
  .crt { position: relative; border: 4px solid #1c476a; border-radius: 12px; background: #060b38; padding: 1.25rem; box-shadow: 0 0 0 4px #060b38, 0 0 40px rgba(80,127,169,0.35); overflow: hidden; }
  .crt::after { content: ""; position: absolute; inset: 0; pointer-events: none; background: repeating-linear-gradient(0deg, rgba(255,255,255,0.03) 0 1px, transparent 1px 3px); border-radius: 8px; }

  .arcade-title { font-size: clamp(1.3rem, 5.5vw, 1.9rem); color: #f2b94b; text-align: center; line-height: 1.6; margin: 0 0 0.35rem; text-shadow: 3px 3px 0 #1c476a, 0 0 22px rgba(242,185,75,0.55); }
  .arcade-sub { font-size: 0.6rem; text-align: center; color: #5fc9f2; letter-spacing: 0.2em; margin-bottom: 1.5rem; }
  .blink { animation: arcblink 1.2s steps(1) infinite; }
  @keyframes arcblink { 50% { opacity: 0; } }

  #menuWombat { display: block; margin: 0 auto 1.25rem; image-rendering: pixelated; }

  .cart { display: block; width: 100%; text-align: left; background: #0b1448; border: 3px solid #1c476a; border-radius: 8px; padding: 0.85rem; margin-bottom: 0.85rem; cursor: pointer; color: inherit; font: inherit; transition: transform 0.08s; }
  .cart { border-color: var(--acc, #507fa9); }
  .cart h2 { color: var(--acc, #fdfcfa) !important; }
  .cart:hover, .cart:focus-visible { transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--acc, #1c476a), 0 0 18px color-mix(in srgb, var(--acc) 35%, transparent); outline: none; }
  .cart-row { display: flex; gap: 0.85rem; align-items: center; }
  .cart canvas { image-rendering: pixelated; border: 2px solid #1c476a; border-radius: 4px; flex: 0 0 auto; }
  .cart h2 { font-size: 0.95rem; margin: 0 0 0.55rem; line-height: 1.35; text-shadow: 2px 2px 0 rgba(6,11,56,0.9); }
  .cart p { font-size: 0.55rem; color: #97bcd7; margin: 0; line-height: 1.85; }

  #arcadeStage { display: none; }
  .stage-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem; }
  #hudTitle { font-size: 0.75rem; color: #f2b94b; }
  #btnBack { font: inherit; font-size: 0.5rem; background: none; border: 2px solid #1c476a; color: #97bcd7; padding: 0.4rem 0.6rem; border-radius: 4px; cursor: pointer; }
  #btnBack:hover { border-color: #97bcd7; }
  #arcadeCanvas { width: 100%; height: auto; display: block; image-rendering: pixelated; border: 3px solid #1c476a; border-radius: 6px; background: #060b38; touch-action: none; }
  .stage-hint { font-size: 0.45rem; color: #507fa9; text-align: center; margin-top: 0.6rem; line-height: 1.9; }

  #arcadeOverlay { display: none; position: absolute; inset: 0; background: rgba(6,11,56,0.93); z-index: 5; border-radius: 8px; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 1.5rem; }
  #ovTitle { font-size: 1rem; color: #f2b94b; margin: 0 0 1rem; text-shadow: 2px 2px 0 #1c476a; }
  #ovLine { font-size: 0.55rem; color: #cadbe5; line-height: 2; margin: 0 0 0.75rem; max-width: 34ch; }
  #ovBest { font-size: 0.5rem; color: #97bcd7; margin: 0 0 1.25rem; min-height: 1em; }
  .ov-cta { font-size: 0.5rem; color: #060b38; background: #f2b94b; text-decoration: none; padding: 0.7rem 0.9rem; border-radius: 4px; line-height: 1.7; display: inline-block; margin-bottom: 1.1rem; }
  .ov-cta:hover { background: #97bcd7; }
  .ov-btns { display: flex; gap: 0.75rem; }
  .ov-btns button { font: inherit; font-size: 0.5rem; background: none; border: 2px solid #507fa9; color: #cadbe5; padding: 0.6rem 0.8rem; border-radius: 4px; cursor: pointer; }
  .ov-btns button:hover { border-color: #97bcd7; }

  .menu-btn { display: block; width: 100%; font: inherit; font-size: 0.75rem; text-align: center; background: none; border: 3px solid #f2b94b; color: #f2b94b; padding: 0.85rem; border-radius: 8px; cursor: pointer; margin-top: 0.35rem; text-shadow: 2px 2px 0 rgba(6,11,56,0.9); }
  .menu-btn:hover, .menu-btn:focus-visible { background: rgba(242,185,75,0.12); transform: translate(-2px,-2px); box-shadow: 4px 4px 0 #f2b94b; outline: none; }
  #scorePanel { display: none; }
  #scorePanel h2 { font-size: 0.95rem; color: #f2b94b; text-align: center; margin: 0 0 1rem; text-shadow: 2px 2px 0 #1c476a; }
  #scoreList h3 { font-size: 0.7rem; color: #5fc9f2; margin: 1.1rem 0 0.5rem; }
  .lb-list { list-style: none; counter-reset: lb; margin: 0; padding: 0; }
  .lb-list li { counter-increment: lb; display: flex; justify-content: space-between; font-size: 0.6rem; color: #cadbe5; padding: 0.3rem 0.2rem; border-bottom: 1px solid #1c476a; }
  .lb-list li::before { content: counter(lb) "."; color: #507fa9; margin-right: 0.6rem; }
  .lb-list li span:first-of-type { flex: 1; }
  .lb-empty { font-size: 0.5rem; color: #507fa9; line-height: 1.9; }
  #lbRow { display: none; gap: 0.5rem; align-items: center; justify-content: center; margin-bottom: 1rem; flex-wrap: wrap; }
  #lbInitials { font: inherit; font-size: 0.75rem; width: 4.2ch; text-align: center; text-transform: uppercase; background: #060b38; border: 2px solid #507fa9; color: #f2b94b; padding: 0.45rem 0.2rem; border-radius: 4px; }
  #lbInitials:focus { border-color: #f2b94b; outline: none; }
  #btnSubmit { font: inherit; font-size: 0.5rem; background: none; border: 2px solid #5fd39a; color: #5fd39a; padding: 0.55rem 0.7rem; border-radius: 4px; cursor: pointer; }
  #btnSubmit:hover { background: rgba(95,211,154,0.12); }
  #lbStatus { width: 100%; text-align: center; font-size: 0.5rem; color: #f2b94b; min-height: 1em; margin: 0; }

  .arcade-fineprint { font-size: 0.45rem; color: #507fa9; text-align: center; margin-top: 1.5rem; line-height: 2; }
  .arcade-fineprint a { color: #97bcd7; }
</style>

<section class="arcade-section">
  <div class="container">
    <div class="arcade-wrap">

      <h1 class="arcade-title">WOMBAT ARCADE</h1>
      <p class="arcade-sub">JUST4FUN <span class="blink">▮</span></p>

      <div class="crt" style="position: relative;">

        {# ── MENU ── #}
        <div id="arcadeMenu">
          <canvas id="menuWombat" width="112" height="90" aria-hidden="true"></canvas>

          <button class="cart" data-game="dash" style="--acc:#f2b94b;">
            <div class="cart-row">
              <canvas width="110" height="80" aria-hidden="true"></canvas>
              <div>
                <h2>DEPOSIT DASH</h2>
                <p>Catch the coins. Dodge the rate rises. Mind the brunch. First to $100k buys.</p>
              </div>
            </div>
          </button>

          <button class="cart" data-game="pong" style="--acc:#5fd39a;">
            <div class="cart-row">
              <canvas width="110" height="80" aria-hidden="true"></canvas>
              <div>
                <h2>BUYER vs SELLER</h2>
                <p>The classic negotiation. First to five settles the deal. The vendor plays dirty.</p>
              </div>
            </div>
          </button>

          <button class="cart" data-game="stack" style="--acc:#ff8a5c;">
            <div class="cart-row">
              <canvas width="110" height="80" aria-hidden="true"></canvas>
              <div>
                <h2>THE STACK</h2>
                <p>Build the tower, floor by swinging floor. Sloppy drops get trimmed by the certifier.</p>
              </div>
            </div>
          </button>

          <button class="cart" data-game="openhome" style="--acc:#5fc9f2;">
            <div class="cart-row">
              <canvas width="110" height="80" aria-hidden="true"></canvas>
              <div>
                <h2>OPEN HOME</h2>
                <p>Grab every listing before the agents corner you. Pre-approval makes them run.</p>
              </div>
            </div>
          </button>

          <button class="cart" data-game="waiver" style="--acc:#e05548;">
            <div class="cart-row">
              <canvas width="110" height="80" aria-hidden="true"></canvas>
              <div>
                <h2>WAIVER WOMBAT</h2>
                <p>Hurdle the LMI. Spell W-A-I-V-E-R before the credit policy trips you up.</p>
              </div>
            </div>
          </button>

          <button class="cart" data-game="reno" style="--acc:#b48bff;">
            <div class="cart-row">
              <canvas width="110" height="80" aria-hidden="true"></canvas>
              <div>
                <h2>THE RENOVATOR</h2>
                <p>Knock down every brick of the worst house on the best street. Mind the budget.</p>
              </div>
            </div>
          </button>

          <button class="menu-btn" id="btnScores" type="button">★ HIGH SCORES ★</button>
        </div>

        {# ── GAME STAGE ── #}
        <div id="arcadeStage">
          <div class="stage-bar">
            <span id="hudTitle">GAME</span>
            <button id="btnBack" type="button">← ARCADE</button>
          </div>
          <canvas id="arcadeCanvas" aria-label="Wombat arcade game"></canvas>
          <p class="stage-hint">ARROWS / SWIPE / DRAG TO MOVE · SPACE / TAP TO JUMP+DROP · ESC FOR MENU</p>
        </div>

        {# ── HIGH SCORES ── #}
        <div id="scorePanel">
          <h2>HIGH SCORES</h2>
          <div id="scoreList"></div>
          <button class="menu-btn" id="btnScoresBack" type="button" style="margin-top:1.25rem;">← ARCADE</button>
        </div>

        {# ── END SCREEN ── #}
        <div id="arcadeOverlay">
          <h2 id="ovTitle">GAME OVER</h2>
          <p id="ovLine"></p>
          <p id="ovBest"></p>
          <div id="lbRow">
            <input id="lbInitials" maxlength="3" placeholder="AAA" aria-label="Your initials" autocomplete="off">
            <button id="btnSubmit" type="button">SUBMIT SCORE</button>
            <p id="lbStatus"></p>
          </div>
          <a class="ov-cta"
             href="https://calendly.com/tom-wombathomeloans"
             target="_blank" rel="noopener"
             data-umami-event="book-a-call"
             data-umami-event-location="just4fun">
            THE REAL-LIFE VERSION IS MY ACTUAL JOB →
          </a>
          <div class="ov-btns">
            <button id="btnAgain" type="button">PLAY AGAIN</button>
            <button id="btnMenu" type="button">ARCADE</button>
          </div>
        </div>

      </div>

      <p class="arcade-fineprint">
        JUST GAMES — DEFINITELY NOT FINANCIAL ADVICE.<br>
        MORTGAGES ARE OVER <a href="/">HERE</a>.
      </p>

    </div>
  </div>
</section>

<script src="/assets/js/arcade.js?v=3" defer></script>
