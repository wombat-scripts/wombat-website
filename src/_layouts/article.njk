---
layout: base.njk
ogType: article
---

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "url": "https://wombathomeloans.com.au{{ page.url }}",
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ date | isoDate }}",
  "author": {
    "@type": "Person",
    "name": "Tom Carr",
    "url": "https://wombathomeloans.com.au",
    "jobTitle": "Mortgage Broker",
    "worksFor": {
      "@type": "Organization",
      "name": "Wombat Home Loans"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Wombat Home Loans",
    "url": "https://wombathomeloans.com.au",
    "logo": {
      "@type": "ImageObject",
      "url": "https://wombathomeloans.com.au/assets/logo-horizontal.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://wombathomeloans.com.au{{ page.url }}"
  }
}
</script>
{% endblock %}

<article class="section">
  <div class="container container--narrow">
    <p class="eyebrow">{{ category or "Home Loans" }}</p>
    <h1>{{ title }}</h1>
    {% if date %}<p class="meta">{{ date | readableDate }} · {{ category or "Home Loans" }}</p>{% endif %}

    {% include "partials/article-video.njk" %}

    <div class="article-body">
      {{ content | safe }}
    </div>

    {# ── Related articles ── #}
    {% set related = [] %}{% for a in collections.articles %}{% if a.url != page.url %}{% set related = (related.push(a), related) %}{% endif %}{% endfor %}{% set related = related | limit(3) %}
    {% if related.length %}
    <div style="margin-top: var(--space-8); padding-top: var(--space-6); border-top: 1px solid var(--line);">
      <h3>You might also find useful</h3>
      <ul style="padding-left: 0; list-style: none;">
        {% for article in related %}
        <li style="margin-bottom: var(--space-3);">
          <a href="{{ article.url }}" style="font-weight: 500;">{{ article.data.title }}</a>
          <span class="meta" style="display: block;">{{ article.data.category or "Home Loans" }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    <div style="margin-top: var(--space-7); padding-top: var(--space-6); border-top: 1px solid var(--line);">
      <h3>Questions about {{ category | lower or "your home loan" }}?</h3>
      <p>Book a free discovery call — no obligation, no jargon.</p>
      {% cta "Book a free discovery call" %}
    </div>
  </div>
</article>
