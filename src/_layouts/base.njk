<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title }} | Wombat Home Loans</title>
  <meta name="description" content="{{ description or 'Mortgage broker for corporate professionals — bonus income, RSUs, SMSF and first homes. 20+ years inside the banks. 40+ lenders. No cost to you.' }}">
  <meta name="author" content="Tom Carr">

  <link rel="canonical" href="https://wombathomeloans.com.au{{ page.url }}">
  <meta name="robots" content="index, follow, max-image-preview:large">

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  <script src="/pagefind/pagefind-ui.js"></script>

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <meta name="theme-color" content="#1c476a">

  {# Open Graph #}
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="Wombat Home Loans">
  <meta property="og:title" content="{{ ogTitle or title }}">
  <meta property="og:description" content="{{ description or 'Mortgage broker for corporate professionals — bonus income, RSUs, SMSF and first homes.' }}">
  <meta property="og:url" content="https://wombathomeloans.com.au{{ page.url }}">
  <meta property="og:image" content="https://wombathomeloans.com.au{{ ogImage or '/assets/og-image.jpg' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_AU">

  {# Twitter / X #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ ogTitle or title }}">
  <meta name="twitter:description" content="{{ description or 'Mortgage broker for corporate professionals — bonus income, RSUs, SMSF and first homes.' }}">
  <meta name="twitter:image" content="https://wombathomeloans.com.au{{ ogImage or '/assets/og-image.jpg' }}">

  {# Fonts #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap">

  {# Stylesheet #}
  <link rel="stylesheet" href="/assets/css/styles.css">

  {# Schema markup — injected per-page via block #}
  {% block schema %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://wombathomeloans.com.au/#tom-carr",
        "name": "Tom Carr",
        "jobTitle": "Mortgage Broker",
        "url": "https://wombathomeloans.com.au/",
        "image": "https://wombathomeloans.com.au/images/tom-hero-01.jpg",
        "telephone": "+61456255409",
        "email": "tom@wombathomeloans.com.au",
        "sameAs": ["https://linkedin.com/in/tomrcarr", "https://www.youtube.com/@thepropertyweb"],
        "worksFor": { "@id": "https://wombathomeloans.com.au/#wombat-home-loans" }
      },
      {
        "@type": ["FinancialService", "MortgageBroker"],
        "@id": "https://wombathomeloans.com.au/#wombat-home-loans",
        "name": "Wombat Home Loans",
        "url": "https://wombathomeloans.com.au/",
        "telephone": "+61456255409",
        "email": "tom@wombathomeloans.com.au",
        "description": "Mortgage broker for corporate professionals — first home buyers with complex income (bonus, RSUs, ESS), SMSF and structured lending, refinancing, and asset finance. 20+ years institutional banking experience. Access to 40+ lenders. No cost to borrower.",
        "founder": { "@id": "https://wombathomeloans.com.au/#tom-carr" },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Sydney",
          "addressRegion": "NSW",
          "addressCountry": "AU"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -33.7511,
          "longitude": 151.0759
        },
        "areaServed": [
          { "@type": "City", "name": "Sydney" },
          { "@type": "Country", "name": "Australia" }
        ],
        "serviceType": ["Mortgage Broking", "Home Loans", "Expat Lending", "Refinancing", "Investment Loans", "First Home Buyer Loans"],
        "priceRange": "Free to borrower (commission-paid by lender)",
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "17:00"
        },
        "sameAs": ["https://www.google.com/maps/place/Wombat+Home+Loans/"],
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5.0",
          "bestRating": "5",
          "ratingCount": "12"
        }
      }
    ]
  }
  </script>
  {% endblock %}

  {% block head %}{% endblock %}

<script defer src="https://cloud.umami.is/script.js" data-website-id="7d4d19f7-1636-4f25-be1c-bd58b7fe237b"></script>

</head>
<body>

  {# ── NAV ── #}
  {% include "nav.njk" %}

  {# ── MAIN CONTENT ── #}
  <main>
    {{ content | safe }}
  </main>

  {# ── FOOTER ── #}
  {% include "footer.njk" %}

  <script src="/assets/js/scripts.js" defer></script>
  {% block scripts %}{% endblock %}
</body>
</html>
