    { "@type": "Question", "name": "Does it cost anything to use a mortgage broker?", "acceptedAnswer": { "@type": "Answer", "text": "No. Wombat Home Loans is paid by the lender when your loan settles. There is no cost to the borrower. Under Australia's Best Interests Duty, brokers are legally required to act in your interests." } },
    { "@type": "Question", "name": "Can you help if I'm an Australian living overseas?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. This is one of Wombat's specialist areas. Tom works with Australian expats in the UK, US, Singapore, Hong Kong, the UAE, and elsewhere who are buying investment property back home or planning their return." } },
    { "@type": "Question", "name": "Can you help if I have foreign income?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Different lenders treat foreign income very differently — some accept 100% of GBP or USD income, others apply heavy haircuts, others won't consider it at all. Tom's specialty is matching your income profile to lenders that will recognise it properly." } },
    { "@type": "Question", "name": "How many lenders do you work with?", "acceptedAnswer": { "@type": "Answer", "text": "40+ lenders, covering the big four banks, second-tier banks, non-bank lenders, and specialist lenders for non-standard cases." } },
