{% block scripts %}
<script>
(function() {
  var scroller = document.getElementById('articles-scroller');
  var prev = document.getElementById('articles-prev');
  var next = document.getElementById('articles-next');
  if (!scroller || !prev || !next) return;
  var card = scroller.querySelector('.card');
  function getStep() { return card ? card.offsetWidth + 20 : 320; }
  prev.addEventListener('click', function() { scroller.scrollBy({ left: -getStep(), behavior: 'smooth' }); });
  next.addEventListener('click', function() { scroller.scrollBy({ left: getStep(), behavior: 'smooth' }); });
})();

(function() {
  var scroller = document.getElementById('podcast-scroller');
  var prev = document.getElementById('podcast-prev');
  var next = document.getElementById('podcast-next');
  if (!scroller || !prev || !next) return;
  var card = scroller.querySelector('.card');
  function getStep() { return card ? card.offsetWidth + 20 : 320; }
  prev.addEventListener('click', function() { scroller.scrollBy({ left: -getStep(), behavior: 'smooth' }); });
  next.addEventListener('click', function() { scroller.scrollBy({ left: getStep(), behavior: 'smooth' }); });
})();
</script>
{% endblock %}
