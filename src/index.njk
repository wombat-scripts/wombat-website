{# ── PAGE-LOCAL STYLES ── #}
{% block head %}
<style>
  /* Hero layout */
  .hero { position: relative; padding-block: clamp(5rem, 10vw, 8rem) clamp(4rem, 8vw, 6rem); overflow: hidden; }
  .hero__inner { display: grid; grid-template-columns: 1fr; gap: var(--space-7); align-items: center; }
  @media (min-width: 960px) { .hero__inner { grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr); gap: var(--space-9); } }
  .hero__copy h1 { margin-top: var(--space-3); margin-bottom: var(--space-5); }
  .hero__lede { margin-bottom: var(--space-6); }
  .hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); margin-bottom: var(--space-7); }
  .hero__trust { display: flex; flex-wrap: wrap; gap: var(--space-5) var(--space-6); align-items: center; padding-top: var(--space-5); border-top: 1px solid var(--line); font-size: var(--fs-small); color: var(--ink-soft); }
  .hero__trust strong { color: var(--navy-deep); font-weight: 600; }
  .hero__stars { display: inline-flex; gap: 2px; color: var(--gold); }
  .hero__stars svg { width: 16px; height: 16px; fill: currentColor; }

  /* Hero portrait */
  .hero__portrait { position: relative; aspect-ratio: 4 / 5; max-width: 460px; width: 100%; margin-inline: auto; border-radius: var(--radius-lg); overflow: hidden; background: linear-gradient(135deg, var(--navy), var(--navy-deep)); box-shadow: var(--shadow-xl); }
  .hero__portrait img { width: 100%; height: 100%; object-fit: cover; }
  .hero__portrait::before { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(6, 11, 56, 0.35)); z-index: 1; pointer-events: none; }
  .hero__portrait-tag { position: absolute; bottom: var(--space-4); left: var(--space-4); right: var(--space-4); z-index: 2; color: #fff; font-family: var(--font-display); font-size: 1.125rem; font-weight: 300; font-style: italic; line-height: 1.3; font-variation-settings: "opsz" 144, "SOFT" 100; }
  .hero__portrait-tag small { display: block; font-family: var(--font-body); font-style: normal; font-size: var(--fs-meta); font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue-light); margin-bottom: var(--space-2); }

  /* Decorative hero accent */
  .hero__accent { position: absolute; top: -10%; right: -8%; width: 38%; height: 120%; opacity: 0.04; pointer-events: none; z-index: 0; }
  .hero__inner > * { position: relative; z-index: 1; }

  /* Photo slots (placeholder until photos sourced) */
  .photo-slot { position: relative; border-radius: var(--radius-md); overflow: hidden; display: flex; flex-direction: column; justify-content: flex-end; padding: var(--space-5); border: 1px solid; min-height: 280px; }
  .photo-slot::before { content: ''; position: absolute; inset: 0; opacity: 0.05; background-image: repeating-linear-gradient(45deg, currentColor 0 1px, transparent 1px 14px); pointer-events: none; }
  .photo-slot__label { position: absolute; top: var(--space-3); left: var(--space-3); font-size: 11px; font-family: ui-monospace, SFMono-Regular, monospace; letter-spacing: 0.15em; opacity: 0.55; z-index: 1; }
  .photo-slot__brief { position: relative; font-size: var(--fs-small); line-height: 1.4; font-weight: 500; opacity: 0.85; max-width: 32ch; }
  .photo-slot--navy { background: linear-gradient(135deg, var(--navy), var(--navy-deep)); color: rgba(255,255,255,0.85); border-color: rgba(255,255,255,0.12); }
  .photo-slot--pale { background: linear-gradient(135deg, var(--blue-pale), var(--blue-light)); color: rgba(28,71,106,0.85); border-color: rgba(28,71,106,0.18); }
  .photo-slot--warm { background: var(--paper-warm); color: var(--ink-soft); border-color: var(--line); }
  .photo-slot--ratio-4-5 { aspect-ratio: 4/5; }
  .photo-slot--ratio-4-3 { aspect-ratio: 4/3; }

  /* Story section — editorial alternating rows */
  .story__row { display: grid; grid-template-columns: 1fr; gap: var(--space-6); align-items: center; }
  @media (min-width: 800px) { .story__row { grid-template-columns: 1fr 1fr; gap: var(--space-8); } .story__row--reverse .story__media { order: 2; } }

  /* Help cards */
  .help-grid { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .help-card { padding: var(--space-6); }
  .help-card__icon { width: 44px; height: 44px; display: inline-flex; align-items: center; justify-content: center; background: var(--blue-pale); color: var(--navy); border-radius: var(--radius-md); margin-bottom: var(--space-4); }
  .help-card__icon svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
  .help-card h3 { font-size: 1.375rem; margin-bottom: var(--space-3); }
  .help-card ul { list-style: none; padding: 0; margin: var(--space-4) 0 0; font-size: var(--fs-small); }
  .help-card li { padding-left: 1.25rem; position: relative; color: var(--ink-soft); }
  .help-card li::before { content: ""; position: absolute; left: 0; top: 0.6em; width: 8px; height: 1px; background: var(--steel); }

  /* Process steps */
  .process { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); counter-reset: step; }
  .process__step { position: relative; padding: var(--space-5) 0 0; }
  .process__step::before { counter-increment: step; content: counter(step, decimal-leading-zero); display: block; font-family: var(--font-display); font-size: 2.25rem; font-weight: 300; color: var(--steel); font-variation-settings: "opsz" 144, "SOFT" 100; line-height: 1; margin-bottom: var(--space-4); }
  .process__step h3 { font-size: 1.25rem; margin-bottom: var(--space-3); }
  .process__step p { font-size: var(--fs-small); color: var(--ink-soft); }

  /* Reviews */
  .reviews { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .review-card { padding: var(--space-6); display: flex; flex-direction: column; }
  .review-card__quote { font-family: var(--font-display); font-size: 1.25rem; font-weight: 300; line-height: 1.45; color: var(--navy-deep); margin: 0 0 var(--space-5); font-variation-settings: "opsz" 80, "SOFT" 50; }
  .review-card__quote::before { content: "\201C"; display: block; font-size: 3rem; line-height: 0.6; color: var(--blue-light); margin-bottom: var(--space-3); }
  .review-card__attr { margin-top: auto; font-size: var(--fs-small); color: var(--ink-muted); display: flex; justify-content: space-between; gap: var(--space-3); }
  .review-card__name { color: var(--ink); font-weight: 600; }

  /* Newsletter card */
  .newsletter { background: #fff; border: 1px solid var(--line); border-radius: var(--radius-lg); padding: clamp(2rem, 4vw, 3rem); max-width: 720px; margin-inline: auto; box-shadow: var(--shadow-md); }
  .newsletter form { display: flex; gap: var(--space-3); flex-wrap: wrap; margin-top: var(--space-5); }
  .newsletter input[type="email"] { flex: 1 1 240px; padding: 0.95rem 1.1rem; font: inherit; border: 1px solid var(--line); border-radius: var(--radius-pill); background: var(--paper); color: var(--ink); }
  .newsletter input[type="email"]:focus { outline: 2px solid var(--steel); outline-offset: 2px; border-color: var(--steel); }

  /* Podcast grid */
  .podcast-grid { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .episode-card { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
  .episode-card__num { font-family: var(--font-display); font-size: 0.9375rem; font-weight: 500; letter-spacing: 0.08em; color: var(--steel); text-transform: uppercase; }
  .episode-card h3 { font-size: 1.125rem; line-height: 1.35; margin-bottom: var(--space-2); }
  .episode-card__meta { font-size: var(--fs-meta); color: var(--ink-muted); margin-top: auto; }

  /* Tools strip */
  .tools-strip { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .tool-card { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-6); background: linear-gradient(180deg, #fff, var(--paper-cool)); }
  .tool-card h3 { font-size: 1.25rem; margin-bottom: var(--space-2); }
  .tool-card p { font-size: var(--fs-small); color: var(--ink-soft); margin: 0; }
  .tool-card__link { margin-top: auto; padding-top: var(--space-4); }

  /* Articles preview */
  .articles-grid { display: grid; gap: var(--space-5); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .article-card { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); }
  .article-card__cat { font-size: var(--fs-meta); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--steel); }
  .article-card h3 { font-size: 1.1875rem; line-height: 1.35; margin-bottom: var(--space-2); }
  .article-card__meta { font-size: var(--fs-meta); color: var(--ink-muted); margin-top: auto; }

  /* FAQ */
  .faq { max-width: var(--container-narrow); margin-inline: auto; }
  .faq details { border-top: 1px solid var(--line); padding: var(--space-5) 0; }
  .faq details:last-of-type { border-bottom: 1px solid var(--line); }
  .faq summary { cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); font-family: var(--font-display); font-size: 1.1875rem; font-weight: 400; color: var(--navy-deep); line-height: 1.35; font-variation-settings: "opsz" 36, "SOFT" 50; }
  .faq summary::after { content: "+"; font-size: 1.25rem; color: var(--steel); flex-shrink: 0; transition: transform var(--motion-fast) var(--easing); }
  .faq details[open] summary::after { content: "−"; }
  .faq details p { margin-top: var(--space-3); font-size: var(--fs-small); color: var(--ink-soft); max-width: 60ch; }
  .faq summary::-webkit-details-marker { display: none; }

  /* Closing CTA */
  .closing { display: grid; grid-template-columns: 1fr; gap: var(--space-7); align-items: center; }
  @media (min-width: 800px) { .closing { grid-template-columns: 1fr 1.2fr; gap: var(--space-9); } }
  .closing h2 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); }

  /* Lender strip */
  .lender-strip { padding-block: clamp(2rem, 4vw, 3rem); border-block: 1px solid var(--line); }
  .lender-strip__label { text-align: center; margin-bottom: var(--space-4); }
  .lender-name { font-family: var(--font-display); font-size: 1.125rem; font-weight: 400; color: var(--ink-muted); font-variation-settings: "opsz" 36, "SOFT" 50; letter-spacing: -0.01em; white-space: nowrap; }

  /* Logo + button fixes from v3 */
  .nav__brand-mark { width: 36px !important; height: 36px !important; flex: 0 0 auto; }
  .footer__brand img { width: 40px !important; height: 40px !important; flex: 0 0 auto; }
  .nav__cta .btn--primary { background: var(--navy) !important; color: #fff !important; isolation: isolate; }
  .nav__cta .btn--primary:hover { background: var(--navy-deep) !important; color: #fff !important; }

  /* Cooler paper tones override */
  :root { --paper: #ffffff; --paper-warm: #f3f6f9; --paper-cool: #f3f6f9; }

  @media (max-width: 640px) { .hero { padding-block: 4rem 3rem; } .hero__portrait { max-width: 360px; } }
</style>
{% endblock %}

